@{
    ViewBag.Title = "Acerca de";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card animate__animated animate__fadeInUp">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <i class="fas fa-calendar-alt fa-4x text-primary"></i>
                    </div>
                    
                    <h1 class="h2 text-primary mb-4">@ViewBag.Message</h1>
                    
                    <p class="lead mb-4">
                        Una aplicación moderna de gestión de eventos construida con las últimas tecnologías web.
                    </p>
                    
                    <div class="row text-start">
                        <div class="col-md-6">
                            <h3 class="h5 text-primary mb-3">
                                <i class="fas fa-cogs me-2"></i>Tecnologías
                            </h3>
                            <ul class="list-unstyled">
                                <li class="mb-2">
                                    <i class="fas fa-server text-muted me-2"></i>
                                    <strong>Backend:</strong> ASP.NET MVC 5 (C#)
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-code text-muted me-2"></i>
                                    <strong>Frontend:</strong> jQuery 3.x
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-calendar text-muted me-2"></i>
                                    <strong>Calendario:</strong> FullCalendar.js v6
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-paint-brush text-muted me-2"></i>
                                    <strong>Estilos:</strong> Bootstrap 5
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-database text-muted me-2"></i>
                                    <strong>Persistencia:</strong> Sesión del navegador
                                </li>
                            </ul>
                        </div>
                        
                        <div class="col-md-6">
                            <h3 class="h5 text-primary mb-3">
                                <i class="fas fa-star me-2"></i>Características
                            </h3>
                            <ul class="list-unstyled">
                                <li class="mb-2">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    Interfaz intuitiva y moderna
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    Creación y edición de eventos
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    Arrastrar y soltar eventos
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    Múltiples vistas de calendario
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    Eventos de todo el día
                                </li>
                                <li class="mb-2">
                                    <i class="fas fa-check-circle text-success me-2"></i>
                                    Personalización de colores
                                </li>
                            </ul>
                        </div>
                    </div>
                    
                    <div class="mt-5">
                        <h3 class="h5 text-primary mb-3">
                            <i class="fas fa-palette me-2"></i>Librerías UI/UX
                        </h3>
                        <div class="row">
                            <div class="col-md-3 col-sm-6 mb-2">
                                <span class="badge bg-primary fs-6">SweetAlert2</span>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-2">
                                <span class="badge bg-success fs-6">Bootstrap 5</span>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-2">
                                <span class="badge bg-info fs-6">Animate.css</span>
                            </div>
                            <div class="col-md-3 col-sm-6 mb-2">
                                <span class="badge bg-warning fs-6">FontAwesome</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-5">
                        <a href="@Url.Action("Index", "Calendar")" class="btn btn-primary btn-lg">
                            <i class="fas fa-arrow-left me-2"></i>Volver al Calendario
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>